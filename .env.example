# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# LocalStack Configuration (for development)
AWS_ENDPOINT_URL=http://localhost:4566
LOCALSTACK_API_KEY=your-localstack-pro-key

# Cognito Configuration
USER_POOL_ID=your-user-pool-id
USER_POOL_CLIENT_ID=your-user-pool-client-id
IDENTITY_POOL_ID=your-identity-pool-id

# S3 Configuration
S3_BUCKET=dharohar-media-bucket-name

# API Gateway
API_GATEWAY_URL=your-api-gateway-url

# QLDB Configuration
QLDB_LEDGER_NAME=dharohar-sovereignty

# Mobile App Environment Variables (Expo)
EXPO_PUBLIC_AWS_REGION=us-east-1
EXPO_PUBLIC_USER_POOL_ID=your-user-pool-id
EXPO_PUBLIC_USER_POOL_CLIENT_ID=your-user-pool-client-id
EXPO_PUBLIC_IDENTITY_POOL_ID=your-identity-pool-id
EXPO_PUBLIC_S3_BUCKET=dharohar-media-bucket-name
EXPO_PUBLIC_API_GATEWAY_URL=your-api-gateway-url

# Development Settings
NODE_ENV=development
DEBUG=true
PERSISTENCE=1