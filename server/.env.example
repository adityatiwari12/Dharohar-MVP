# ─── DHAROHAR Server Environment Variables ───────────────────────────────────
#
# STEP 1 — MongoDB Atlas (free cloud database)
# ────────────────────────────────────────────
# 1. Go to https://cloud.mongodb.com → Sign Up (free)
# 2. Create a FREE Cluster (M0 — Shared, always free)
# 3. In "Database Access": create a DB user (e.g. dharohar_user / your_password)
# 4. In "Network Access": Add IP Address → Allow Access from Anywhere (0.0.0.0/0)
# 5. Click "Connect" → "Drivers" → copy the connection string
#    It will look like:
#    mongodb+srv://dharohar_user:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# 6. Replace <password> with your actual password
# 7. Paste it below as MONGO_URI

MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dharohar?retryWrites=true&w=majority&appName=Cluster0

# ─── JWT Authentication ────────────────────────────────────────────────────────
# A long random secret string used to sign tokens. Keep this private.
# Generate one at: https://jwtsecret.com/generate  OR use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_STRING_AT_LEAST_32_CHARS

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Used to generate structured governance metadata on asset submission.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# ─── Media URL Origin ─────────────────────────────────────────────────────────
# The public-facing origin of this server, used to build absolute media URLs.
# Without this, audio/video src attributes resolve against the frontend origin.
# Local: leave blank (defaults to http://localhost:PORT)
# Render / Production: set to your Render service URL e.g. https://dharohar-backend.onrender.com
SERVER_ORIGIN=
